{
  "experiment_name": "demo_rgbd_unet",
  "dataset": {
    "data_dir": "data/raw/nyuv2",
    "image_size": [128, 128],
    "train_split": "train",
    "valid_split": "valid",
    "test_split": "test",
    "num_classes": 41,
    "ignore_index": 255
  },
  "model": {
    "base_channels": 8,
    "dropout": 0.0,
    "use_depth": true
  },
  "training": {
    "batch_size": 2,
    "num_workers": 0,
    "epochs": 1,
    "learning_rate": 0.0005,
    "weight_decay": 0.0,
    "seed": 42,
    "amp": false,
    "max_grad_norm": 1.0
  },
  "output": {
    "root_dir": "outputs"
  }
}
